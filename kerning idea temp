/* =========================================
   GLOBAL UTILITIES (Layered Text Engine)
   ========================================= */

function initCascadeReveal() {
    const targets = document.querySelectorAll('.animate-cascade');
    
    targets.forEach(el => {
        if (el.classList.contains('is-initialized')) return;

        // 1. Snapshot the Original HTML (to preserve inline colors/tags)
        // We use a helper to wrap every single character in a standard <span>
        const originalHTML = el.innerHTML;
        const tempDiv = document.createElement('div');
        tempDiv.innerHTML = originalHTML;
        
        // Recursive function to wrap chars without breaking HTML structure
        let charCount = 0;
        const wrapChars = (node) => {
            if (node.nodeType === 3) { // Text Node
                const text = node.nodeValue;
                if (!text.trim()) return; // Skip empty whitespace
                
                const fragment = document.createDocumentFragment();
                text.split('').forEach(char => {
                    // We only wrap actual visible characters
                    const span = document.createElement('span');
                    span.classList.add('char-reveal');
                    span.dataset.index = charCount++; // Tag it with an ID
                    span.innerText = char;
                    fragment.appendChild(span);
                });
                node.replaceWith(fragment);
            } else if (node.nodeType === 1) { // Element Node
                Array.from(node.childNodes).forEach(wrapChars);
            }
        };
        Array.from(tempDiv.childNodes).forEach(wrapChars);
        
        // 2. Create the "Spacer" (Invisible Copy for Layout)
        const spacer = document.createElement('div');
        spacer.className = 'cascade-spacer';
        spacer.innerHTML = tempDiv.innerHTML; // Contains the wrapped chars
        
        // 3. Create Layers (One Layer per Character)
        const layersFragment = document.createDocumentFragment();
        
        for (let i = 0; i < charCount; i++) {
            const layer = document.createElement('div');
            layer.className = 'cascade-layer';
            
            // Clone the full text structure
            const contentClone = tempDiv.cloneNode(true);
            
            // Find the specific character for this layer and highlight it
            const targetChar = contentClone.querySelector(`[data-index="${i}"]`);
            if (targetChar) {
                targetChar.classList.add('is-target');
            }
            
            // Set Stagger Delay on the LAYER, not the character
            layer.style.transitionDelay = `${i * 30}ms`;
            
            layer.appendChild(contentClone);
            layersFragment.appendChild(layer);
        }

        // 4. Update DOM
        el.innerHTML = ''; // Clear original
        el.appendChild(spacer); // Add spacer
        el.appendChild(layersFragment); // Add animated layers
        
        el.classList.add('is-initialized');
    });
}

window.playCascade = (element) => {
    return new Promise(resolve => {
        if (!element) { resolve(); return; }
        const layers = element.querySelectorAll('.cascade-layer');
        
        layers.forEach(layer => {
            layer.classList.add('is-visible');
        });

        // Wait for the last layer to finish
        if(layers.length > 0) {
            const lastLayer = layers[layers.length - 1];
            window.AnimationUtils.waitForTransition(lastLayer).then(resolve);
        } else {
            resolve();
        }
    });
};

window.reverseCascade = (element) => {
    return new Promise(resolve => {
        if (!element) { resolve(); return; }
        const layers = element.querySelectorAll('.cascade-layer');
        
        layers.forEach((layer, index) => {
            // Reverse stagger logic if you want, or just hide all
            layer.classList.remove('is-visible');
        });
        
        resolve();
    });
};






/* =========================================
   ANIMATIONS: LAYERED TEXT (Perfect Kerning)
   ========================================= */

/* 1. The Container (Holds the layers) */
.animate-cascade {
    position: relative;
    /* We don't hide overflow here so 3D rotation doesn't get clipped */
    overflow: visible; 
    
    /* Ensure the spacer inside dictates the size */
    display: block; 
}

/* 2. The Spacer (Invisible Original Text) */
/* This sits in the flow to give the H1 its height/width */
.cascade-spacer {
    visibility: hidden;
    pointer-events: none;
    display: block; /* Or inline-block depending on context */
}

/* 3. The Layer (One per character) */
/* Each layer contains the FULL text, stacked on top of each other */
.cascade-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    
    /* The Layer handles the movement */
    transform: translateY(110%) rotateX(-20deg);
    transform-origin: bottom center;
    opacity: 1; /* We fade the layer out on exit */
    
    transition: 
        transform var(--time-cascade) var(--ease-standard),
        opacity var(--time-fade-out) ease;
        
    will-change: transform;
}

.cascade-layer.is-visible {
    transform: translateY(0) rotateX(0deg);
    opacity: 1;
}

/* 4. The Characters (Inside the layers) */
.char-reveal {
    /* CRITICAL: display: inline preserves kerning! */
    display: inline !important; 
    
    /* Default: All characters are invisible placeholders */
    color: transparent; 
}

/* 5. The Target (The one visible char per layer) */
.char-reveal.is-target {
    /* Reveal the color (inherits from parent, supporting inline spans) */
    color: inherit; 
}

/* 6. Utility for Word Breaks */
.word-wrapper {
    display: inline; /* Keep it inline to flow naturally */
    white-space: normal; /* Allow wrapping */
}