{{ 'footer.css' | asset_url | stylesheet_tag }}

<footer id="footer" class="footer-section">
  <div class="marquee-wrapper">
    {%- for block in section.blocks -%}
      {%- if block.type == 'marquee' -%}
        {%- if block.settings.url != blank -%}
        <a href="{{ block.settings.url }}" class="marquee-bar" {{ block.shopify_attributes }}>
        {%- else -%}
        <div class="marquee-bar" {{ block.shopify_attributes }}>
        {%- endif -%}
          <div class="marquee-content{% if block.settings.reverse %} marquee-reverse{% endif %}">
            <span class="marquee-item type-subBold1">{{ block.settings.text }}</span>
            <span class="marquee-item arrow" aria-hidden="true"></span>
          </div>
        {%- if block.settings.url != blank -%}
        </a>
        {%- else -%}
        </div>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="footer-main">
    <div id="footer-gradient-container" data-colors="{% render 'palette-color', source: section.settings.gradient_color_1_source, custom: section.settings.gradient_color_1 %}, {% render 'palette-color', source: section.settings.gradient_color_2_source, custom: section.settings.gradient_color_2 %}, {% render 'palette-color', source: section.settings.gradient_color_3_source, custom: section.settings.gradient_color_3 %}">
      <canvas id="footer-canvas"></canvas>
    </div>

    <div class="footer-links">
      {%- for i in (1..6) -%}
        {%- assign fl_label_key = 'footer_link_' | append: i | append: '_label' -%}
        {%- assign fl_url_key = 'footer_link_' | append: i | append: '_url' -%}
        {%- assign fl_contact_key = 'footer_link_' | append: i | append: '_is_contact_trigger' -%}
        {%- assign fl_topic_key = 'footer_link_' | append: i | append: '_contact_topic' -%}
        {%- assign fl_tab_key = 'footer_link_' | append: i | append: '_open_new_tab' -%}
        {%- if settings[fl_label_key] != blank -%}
          <a href="{{ settings[fl_url_key] | default: '#' }}" class="type-subRegular1 ui-roll roll-hover"
            {% if settings[fl_contact_key] %}data-contact-trigger{% endif %}
            {% if settings[fl_topic_key] != blank %}data-contact-topic="{{ settings[fl_topic_key] }}"{% endif %}
            {% if settings[fl_tab_key] %}target="_blank" rel="noopener"{% endif %}
          >
            <span class="ui-roll-layer ui-roll-visible">{{ settings[fl_label_key] }}</span>
            <span class="ui-roll-layer ui-roll-hidden">{{ settings[fl_label_key] }}</span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="type-display-hero animate-cascade fit-text">
      {%- assign title_words = settings.footer_title | default: 'Green Tile Social Club' | split: ' ' -%}
      {%- for word in title_words %}
        <span>{{ word }}</span>
      {%- endfor -%}
    </div>
  </div>
</footer>

<script src="{{ 'footer.js' | asset_url }}" defer></script>

