{%- comment -%}
  Resolve event source: specific collection → all active products.
  Manual event_card blocks are still supported as a final fallback.
{%- endcomment -%}
{%- if section.settings.collection != blank -%}
  {%- assign event_source = collections[section.settings.collection].products -%}
{%- else -%}
  {%- assign event_source = collections.all.products -%}
{%- endif -%}

{%- liquid
  assign evt_ns = settings.event_metafield_namespace | default: 'event_ticketing'
  assign evt_key = settings.event_metafield_key | default: 'event_v2'

  assign current_month = 'now' | date: '%m' | plus: 0
  assign current_year = 'now' | date: '%Y'
  assign today_date = 'now' | date: '%Y-%m-%d'

  if current_month >= 3 and current_month <= 5
    assign season_start = current_year | append: '-03-01'
    assign season_end = current_year | append: '-05-31'
  elsif current_month >= 6 and current_month <= 8
    assign season_start = current_year | append: '-06-01'
    assign season_end = current_year | append: '-08-31'
  elsif current_month >= 9 and current_month <= 11
    assign season_start = current_year | append: '-09-01'
    assign season_end = current_year | append: '-11-30'
  else
    if current_month == 12
      assign season_start = current_year | append: '-12-01'
      assign next_year = current_year | plus: 1
      assign season_end = next_year | append: '-02-28'
    else
      assign prev_year = current_year | minus: 1
      assign season_start = prev_year | append: '-12-01'
      assign season_end = current_year | append: '-02-28'
    endif
  endif
-%}

{%- comment -%}
  Same signals as calendar rows that become real ticket links (not calendar-row--upcoming, not sold-out):
  in-season dated event, not before today, not tagged upcoming, still available, has a poster image.
  Omitting these here keeps sorted_event_entries aligned with what the grid can actually show.
{%- endcomment -%}
{%- assign sorted_event_lines = '' -%}
{%- for product in event_source -%}
  {%- liquid
    assign ev = product.metafields[evt_ns][evt_key].value
    assign event_date_str = nil
    if ev
      assign event_date_str = ev.starts_at | date: '%Y-%m-%d'
    endif

    assign is_coming_soon_tag = false
  -%}
  {%- for tag in product.tags -%}
    {%- assign tag_lower = tag | downcase -%}
    {%- if tag_lower == 'upcoming' -%}
      {%- assign is_coming_soon_tag = true -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
  {%- liquid
    assign event_passed = false
    if event_date_str and event_date_str < today_date
      assign event_passed = true
    endif

    assign in_home_window = false
    if event_date_str and event_date_str >= season_start and event_date_str <= season_end and event_date_str >= today_date
      assign in_home_window = true
    endif

    assign include_event = false
    if in_home_window and is_coming_soon_tag == false and product.available and event_passed == false and product.featured_image
      assign include_event = true
    endif
  -%}
  {%- if include_event -%}
    {%- assign sort_key = event_date_str | replace: '-', '' -%}
    {%- capture sorted_event_lines -%}
      {{- sorted_event_lines -}}
      {{- sort_key -}}::{{- product.handle -}}||
    {%- endcapture -%}
  {%- endif -%}
{%- endfor -%}

{%- assign sorted_event_entries = sorted_event_lines | split: '||' | sort -%}

{%- comment -%}
  Count rows the grid would output: handle resolves and still has a poster (matches .event-card with img).
{%- endcomment -%}
{%- assign resolvable_event_count = 0 -%}
{%- for entry in sorted_event_entries -%}
  {%- if entry == blank -%}{%- continue -%}{%- endif -%}
  {%- assign entry_parts = entry | split: '::' -%}
  {%- assign vis_handle = entry_parts[1] -%}
  {%- assign vis_product = all_products[vis_handle] -%}
  {%- if vis_product == blank or vis_product.featured_image == blank -%}{%- continue -%}{%- endif -%}
  {%- assign resolvable_event_count = resolvable_event_count | plus: 1 -%}
{%- endfor -%}

{%- assign manual_visible_count = 0 -%}
{%- if resolvable_event_count == 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'event_card' and block.settings.poster -%}
      {%- assign manual_visible_count = manual_visible_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- assign total_visible_events = resolvable_event_count -%}
{%- if total_visible_events == 0 -%}
  {%- assign total_visible_events = manual_visible_count -%}
{%- endif -%}

{%- comment -%} Featured layout gate: toggle on, exactly 1 resolvable event, no standalone featured product {%- endcomment -%}
{%- assign has_featured_product = false -%}
{%- if section.settings.use_featured_layout -%}
  {%- for product in collections.all.products -%}
    {%- for tag in product.tags -%}
      {%- assign tag_lower = tag | downcase -%}
      {%- if tag_lower == 'featured' -%}
        {%- assign has_featured_product = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if has_featured_product -%}{%- break -%}{%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- assign use_featured_layout = false -%}
{%- if section.settings.use_featured_layout and resolvable_event_count == 1 and has_featured_product == false -%}
  {%- assign use_featured_layout = true -%}
{%- endif -%}

{%- comment -%} Nothing would render → skip markup, assets, and script {%- endcomment -%}
{%- if total_visible_events > 0 -%}
{%- capture data_colors -%}
  {%- render 'palette-color', source: section.settings.gradient_color_1_source, custom: section.settings.gradient_color_1 -%}, {%- render 'palette-color', source: section.settings.gradient_color_2_source, custom: section.settings.gradient_color_2 -%}, {%- render 'palette-color', source: section.settings.gradient_color_3_source, custom: section.settings.gradient_color_3 -%}
{%- endcapture -%}

{%- if use_featured_layout -%}
{{ 'section-events.css' | asset_url | stylesheet_tag }}
{{ 'section-featured.css' | asset_url | stylesheet_tag }}

{%- assign feat_event = nil -%}
{%- for entry in sorted_event_entries -%}
  {%- if entry == blank -%}{%- continue -%}{%- endif -%}
  {%- assign entry_parts = entry | split: '::' -%}
  {%- assign feat_event_handle = entry_parts[1] -%}
  {%- assign feat_event = all_products[feat_event_handle] -%}
  {%- if feat_event and feat_event.featured_image -%}{%- break -%}{%- endif -%}
  {%- assign feat_event = nil -%}
{%- endfor -%}

<section id="events" class="featured-section events-as-featured"
  data-colors="{{ data_colors }}"
  data-edge="0"
>
  <div class="featured-bg-wrap">
    {%- if feat_event and feat_event.images.size > 1 -%}
      <img class="featured-bg-img"
        src="{{ feat_event.images[1] | image_url: width: 1920 }}"
        alt="" aria-hidden="true" loading="lazy"
      >
    {%- elsif feat_event and feat_event.featured_image -%}
      <img class="featured-bg-img"
        src="{{ feat_event.featured_image | image_url: width: 1920 }}"
        alt="" aria-hidden="true" loading="lazy"
      >
    {%- endif -%}
  </div>

  <div class="featured-frame">
    <div class="featured-marquee-layer" aria-hidden="true">
      <div class="featured-marquee-track">
        {%- for i in (1..20) -%}
          <span class="featured-marquee-item type-h1">{{ section.settings.title | default: 'upcoming events' | upcase }}</span>
        {%- endfor -%}
      </div>
    </div>

    <div class="featured-poster-wrap">
      {%- if feat_event and feat_event.featured_image -%}
        <a href="{{ feat_event.url }}">
          <img src="{{ feat_event.featured_image | image_url: width: 1920 }}"
            class="featured-img"
            alt="{{ feat_event.title | escape }}"
            loading="lazy"
          >
        </a>
      {%- endif -%}
    </div>

    <div class="featured-marquee-layer featured-marquee-bottom" aria-hidden="true">
      <div class="featured-marquee-track marquee-reverse">
        {%- for i in (1..20) -%}
          <span class="featured-marquee-item type-h1">{{ section.settings.title | default: 'upcoming events' | upcase }}</span>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{%- else -%}
{{ 'section-events.css' | asset_url | stylesheet_tag }}

<section id="events" class="events-section sticky-track"
  data-colors="{{ data_colors }}"
  data-edge="0"
>
  <div class="events-sticky">
    <div class="events-sticky-inner">

      <div class="events-title-wrap">
        <div class="events-title-lines desktop-only">
          <div class="type-display-hero animate-line">{{ section.settings.title | default: 'upcoming events' }}</div>
        </div>
        {%- assign title_words = section.settings.title | default: 'upcoming events' | split: ' ' -%}
        <div class="events-title-lines mobile-only">
          {%- for word in title_words -%}
            <div class="type-display-hero animate-line">{{ word }}</div>
          {%- endfor -%}
        </div>
      </div>

      <div class="events-content">
        <div class="events-grid">
          {%- assign events_shown = 0 -%}
          {%- for entry in sorted_event_entries -%}
            {%- if entry == blank -%}{%- continue -%}{%- endif -%}
            {%- if events_shown >= section.settings.max_events -%}{%- break -%}{%- endif -%}
            {%- assign entry_parts = entry | split: '::' -%}
            {%- assign product_handle = entry_parts[1] -%}
            {%- assign product = all_products[product_handle] -%}
            {%- if product == blank or product.featured_image == blank -%}{%- continue -%}{%- endif -%}
            <a href="{{ product.url }}" class="event-card">
              {%- if product.featured_image -%}
                <img
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  class="event-poster"
                  alt="{{ product.title | escape }}"
                  loading="lazy"
                >
              {%- endif -%}
            </a>
            {%- assign events_shown = events_shown | plus: 1 -%}
          {%- endfor -%}

          {%- comment -%} Manual block fallback when no products found {%- endcomment -%}
          {%- if events_shown == 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'event_card' and block.settings.poster -%}
                <a href="{{ block.settings.url | default: '#' }}" class="event-card" {{ block.shopify_attributes }}>
                  <img
                    src="{{ block.settings.poster | image_url: width: 800 }}"
                    class="event-poster"
                    alt="{{ block.settings.title | escape }}"
                    loading="lazy"
                  >
                </a>
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>

      <div class="events-content-footer">
        <a href="{{ section.settings.browse_url | default: '#' }}" class="cta-btn">
          <div class="ui-roll roll-hover">
            <span class="type-subRegular1 ui-roll-layer ui-roll-visible">{{ section.settings.browse_label | default: 'Browse All Events' }}</span>
            <span class="type-subRegular1 ui-roll-layer ui-roll-hidden">{{ section.settings.browse_label | default: 'Browse All Events' }}</span>
          </div>
        </a>
      </div>

    </div>
  </div>
</section>
{%- endif -%}

<script src="{{ 'section-events.js' | asset_url }}" defer></script>
{%- endif -%}

