{%- liquid
  assign is_subpage = false
  if template.name == 'product' or template.suffix == 'archives'
    assign is_subpage = true
  endif
-%}

<nav class="sticky-nav{% if is_subpage %} nav-subpage{% endif %}">
  {% if is_subpage %}
    <div class="nav-left">
      <a href="{{ settings.nav_back_link | default: routes.root_url }}" class="nav-back-link type-subRegular1 ui-roll roll-hover">
        <span class="ui-roll-layer ui-roll-visible">{{ settings.nav_back_label | default: 'BACK' }}</span>
        <span class="ui-roll-layer ui-roll-hidden">{{ settings.nav_back_label | default: 'BACK' }}</span>
      </a>
    </div>
  {% else %}
    <div class="nav-left">
      <a href="{{ routes.root_url }}" class="logo-link">
        {%- if settings.nav_logo -%}
          <img
            src="{{ settings.nav_logo | image_url: width: 200 }}"
            class="nav-logo"
            alt="{{ shop.name }}"
            width="{{ settings.nav_logo.width }}"
            height="{{ settings.nav_logo.height }}"
            loading="eager"
          >
        {%- else -%}
          <img src="{{ 'gtsc-logo-1tile.svg' | asset_url }}" class="nav-logo" alt="{{ shop.name }}">
        {%- endif -%}
      </a>
    </div>
    <div class="nav-center">
      {%- for i in (1..4) -%}
        {%- assign nav_label_key = 'nav_link_' | append: i | append: '_label' -%}
        {%- assign nav_url_key = 'nav_link_' | append: i | append: '_url' -%}
        {%- if settings[nav_label_key] != blank -%}
          <a href="{{ settings[nav_url_key] }}" class="type-subRegular1 ui-roll roll-hover">
            <span class="ui-roll-layer ui-roll-visible">{{ settings[nav_label_key] }}</span>
            <span class="ui-roll-layer ui-roll-hidden">{{ settings[nav_label_key] }}</span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {% endif %}

  <div class="nav-right">
    <a href="#" class="type-subRegular1 ui-roll roll-hover" data-contact-trigger>
      <span class="ui-roll-layer ui-roll-visible">{{ settings.nav_contact_label | default: 'SAY HI' }}</span>
      <span class="ui-roll-layer ui-roll-hidden">{{ settings.nav_contact_label | default: 'SAY HI' }}</span>
    </a>
  </div>

  <button class="nav-hamburger" aria-label="Menu" aria-expanded="false">
    <span class="hamburger-line"></span>
    <span class="hamburger-line"></span>
  </button>
</nav>

<div class="mobile-menu">
  <div class="mobile-menu-inner">
    <div class="type-subBold1 mobile-menu-subhead">{{ 'general.menu' | t }}</div>
    <a href="{{ routes.root_url }}" class="type-h2 mobile-menu-link animate-cascade">{{ 'general.home' | t }}</a>
    {%- for i in (1..4) -%}
      {%- assign nav_label_key = 'nav_link_' | append: i | append: '_label' -%}
      {%- assign nav_mobile_key = 'nav_link_' | append: i | append: '_mobile_label' -%}
      {%- assign nav_url_key = 'nav_link_' | append: i | append: '_url' -%}
      {%- if settings[nav_label_key] != blank -%}
        <a href="{{ settings[nav_url_key] }}" class="type-h2 mobile-menu-link animate-cascade">{{ settings[nav_mobile_key] | default: settings[nav_label_key] }}</a>
      {%- endif -%}
    {%- endfor -%}
    <a href="#" class="type-h2 mobile-menu-link animate-cascade" data-contact-trigger>{{ settings.nav_contact_label | default: 'Say Hi' }}</a>
  </div>
</div>

{% schema %}
{
  "name": "Header",
  "class": "header-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Navigation links, logo, and labels are configured in Theme settings → Navigation."
    }
  ]
}
{% endschema %}
