<section
  id="about"
  class="about"
  data-colors="{{ section.settings.gradient_color_1 }}, {{ section.settings.gradient_color_2 }}, {{ section.settings.gradient_color_3 }}"
  data-edge="{{ section.settings.gradient_edge }}"
>
  <div class="about-inner">
    <div class="about-text type-h1">{{ section.settings.text }}</div>
    <div class="about-images" hidden aria-hidden="true">
      {% for block in section.blocks %}
        {% if block.type == 'inline_image' and block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 800 }}"
            class="about-inline-img"
            alt="{{ block.settings.image.alt | default: '' }}"
            {{ block.shopify_attributes }}
          >
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
<script src="{{ 'section-about.js' | asset_url }}" defer></script>
<div class="section-spacer"></div>

{% schema %}
{
  "name": "About blurb",
  "settings": [
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Cras at odio nulla. Suspendisse laoreet suscipit enim et mollis. Nunc condimentum felis ac ligula tincidunt, dictum accumsan purus laoreet. Pellentesque fermentum dapibus aliquet. Mauris lectus nulla, tincidunt vitae suscipit vel, porttitor non quam. Praesent volutpat ut diam ut tincidunt. Phasellus tempus nisl eget malesuada rhoncus."
    },
    {
      "type": "color",
      "id": "gradient_color_1",
      "label": "Gradient color 1",
      "default": "#30FA30"
    },
    {
      "type": "color",
      "id": "gradient_color_2",
      "label": "Gradient color 2",
      "default": "#FFFCFA"
    },
    {
      "type": "color",
      "id": "gradient_color_3",
      "label": "Gradient color 3",
      "default": "#feea4f"
    },
    {
      "type": "range",
      "id": "gradient_edge",
      "label": "Gradient edge",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "inline_image",
      "name": "Inline image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "About blurb",
      "blocks": [
        { "type": "inline_image" },
        { "type": "inline_image" },
        { "type": "inline_image" },
        { "type": "inline_image" },
        { "type": "inline_image" }
      ]
    }
  ]
}
{% endschema %}
