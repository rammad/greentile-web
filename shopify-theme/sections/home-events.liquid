{{ 'section-events.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Resolve event source: specific collection → all active products.
  Manual event_card blocks are still supported as a final fallback.
{%- endcomment -%}
{%- if section.settings.collection != blank -%}
  {%- assign event_source = collections[section.settings.collection].products -%}
{%- else -%}
  {%- assign event_source = collections.all.products -%}
{%- endif -%}

<section id="events" class="events-section sticky-track"
  data-colors="{% render 'palette-color', source: section.settings.gradient_color_1_source, custom: section.settings.gradient_color_1 %}, {% render 'palette-color', source: section.settings.gradient_color_2_source, custom: section.settings.gradient_color_2 %}, {% render 'palette-color', source: section.settings.gradient_color_3_source, custom: section.settings.gradient_color_3 %}"
  data-edge="0"
>
  <div class="events-sticky">
    <div class="events-sticky-inner">

      <div class="events-title-wrap">
        <div class="events-title-lines desktop-only">
          <div class="type-display-hero animate-line">{{ section.settings.title | default: 'upcoming events' }}</div>
        </div>
        {%- assign title_words = section.settings.title | default: 'upcoming events' | split: ' ' -%}
        <div class="events-title-lines mobile-only">
          {%- for word in title_words -%}
            <div class="type-display-hero animate-line">{{ word }}</div>
          {%- endfor -%}
        </div>
      </div>

      <div class="events-content">
        <div class="events-grid">
          {%- assign events_shown = 0 -%}
          {%- for product in event_source -%}
            {%- if events_shown >= section.settings.max_events -%}{%- break -%}{%- endif -%}
            <a href="{{ product.url }}" class="event-card">
              {%- if product.featured_image -%}
                <img
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  class="event-poster"
                  alt="{{ product.title | escape }}"
                  loading="lazy"
                >
              {%- endif -%}
            </a>
            {%- assign events_shown = events_shown | plus: 1 -%}
          {%- endfor -%}

          {%- comment -%} Manual block fallback when no products found {%- endcomment -%}
          {%- if events_shown == 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'event_card' -%}
                <a href="{{ block.settings.url | default: '#' }}" class="event-card" {{ block.shopify_attributes }}>
                  {%- if block.settings.poster -%}
                    <img
                      src="{{ block.settings.poster | image_url: width: 800 }}"
                      class="event-poster"
                      alt="{{ block.settings.title | escape }}"
                      loading="lazy"
                    >
                  {%- endif -%}
                </a>
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>

      <div class="events-content-footer">
        <a href="{{ section.settings.browse_url | default: '#' }}" class="cta-btn">
          <div class="ui-roll roll-hover">
            <span class="type-subRegular1 ui-roll-layer ui-roll-visible">{{ section.settings.browse_label | default: 'Browse All Events' }}</span>
            <span class="type-subRegular1 ui-roll-layer ui-roll-hidden">{{ section.settings.browse_label | default: 'Browse All Events' }}</span>
          </div>
        </a>
      </div>

    </div>
  </div>
</section>

<script src="{{ 'section-events.js' | asset_url }}" defer></script>

