<section
  id="featured"
  class="featured-section"
  data-colors="{{ section.settings.gradient_color_1 }}, {{ section.settings.gradient_color_2 }}, {{ section.settings.gradient_color_3 }}"
  data-edge="{{ section.settings.gradient_edge }}"
>
  <div class="featured-bg-wrap">
    {% if section.settings.background_image %}
      <img
        class="featured-bg-img"
        src="{{ section.settings.background_image | image_url: width: 1920 }}"
        alt=""
        aria-hidden="true"
      >
    {% endif %}
  </div>
  <div class="featured-frame">
    <div class="featured-marquee-layer" aria-hidden="true">
      <div class="featured-marquee-track">
        {% for i in (1..20) %}
          <span class="featured-marquee-item type-h1">{{ section.settings.marquee_text }}</span>
        {% endfor %}
      </div>
    </div>
    <div class="featured-poster-wrap">
      {% if section.settings.poster_image %}
        <img
          src="{{ section.settings.poster_image | image_url: width: 1920 }}"
          class="featured-img"
          alt="{{ section.settings.poster_image.alt | default: 'Featured' }}"
        >
      {% endif %}
    </div>
  </div>
</section>
<script src="{{ 'section-featured.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Featured event",
  "settings": [
    {
      "type": "text",
      "id": "marquee_text",
      "label": "Marquee text",
      "default": "FEATURING"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Poster image"
    },
    {
      "type": "color",
      "id": "gradient_color_1",
      "label": "Gradient color 1",
      "default": "#FFFCFA"
    },
    {
      "type": "color",
      "id": "gradient_color_2",
      "label": "Gradient color 2",
      "default": "#D6FED6"
    },
    {
      "type": "color",
      "id": "gradient_color_3",
      "label": "Gradient color 3",
      "default": "#FFFCFA"
    },
    {
      "type": "range",
      "id": "gradient_edge",
      "label": "Gradient edge",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Featured Event"
    }
  ]
}
{% endschema %}
