<footer id="footer" class="footer-section">
  <div class="marquee-wrapper">
    <div class="marquee-bar">
      <div class="marquee-content">
        <span class="marquee-item type-subBold1">{{ settings.footer_marquee_1 }}</span>
        <img class="marquee-item arrow" src="{{ 'arrow-right.png' | asset_url }}" alt="">
      </div>
    </div>
    <div class="marquee-bar">
      <div class="marquee-content marquee-reverse">
        <span class="marquee-item type-subBold1">{{ settings.footer_marquee_2 }}</span>
        <img class="marquee-item arrow" src="{{ 'arrow-right.png' | asset_url }}" alt="">
      </div>
    </div>
  </div>

  <div class="footer-main">
    <div id="footer-gradient-container" data-colors="{{ settings.footer_gradient_color_1 }}, {{ settings.footer_gradient_color_2 }}, {{ settings.footer_gradient_color_3 }}">
      <canvas id="footer-canvas"></canvas>
    </div>
    <div class="footer-links">
      {% for block in section.blocks %}
        {% if block.type == 'footer_link' %}
          <a href="{{ block.settings.url | default: '#' }}" class="type-subRegular1 ui-roll roll-hover" {{ block.shopify_attributes }}>
            <span class="ui-roll-layer ui-roll-visible">{{ block.settings.label }}</span>
            <span class="ui-roll-layer ui-roll-hidden">{{ block.settings.label }}</span>
          </a>
        {% endif %}
      {% endfor %}
    </div>
    <div class="type-display-hero animate-cascade fit-text">
      <span>{{ settings.footer_display_text }}</span>
    </div>
  </div>
</footer>

<script src="{{ 'footer.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Footer",
  "blocks": [
    {
      "type": "footer_link",
      "name": "Footer Link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Link"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        }
      ]
    }
  ]
}
{% endschema %}
