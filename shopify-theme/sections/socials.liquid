<div id="socials" class="socials-section">
  <div class="socials-header">
    <div class="type-h1 animate-cascade">{{ section.settings.heading }}</div>
    <p class="{{ section.settings.body_type_class | default: 'type-body2' }}">{{ section.settings.body_text }}</p>
    <div class="socials-icons">
      {% if settings.social_instagram != blank %}
        <a class="icon-circle icon-instagram" href="{{ settings.social_instagram }}">
          <img src="{{ 'Instagram_Glyph_White.svg' | asset_url }}" alt="Instagram">
        </a>
      {% endif %}
      {% if settings.social_tiktok != blank %}
        <a class="icon-circle icon-tiktok" href="{{ settings.social_tiktok }}">
          <img src="{{ 'tiktok-circle.svg' | asset_url }}" alt="TikTok">
        </a>
      {% endif %}
      {% if settings.social_discord != blank %}
        <a class="icon-circle icon-discord" href="{{ settings.social_discord }}">
          <img src="{{ 'discord-icon-svgrepo-com.svg' | asset_url }}" alt="Discord">
        </a>
      {% endif %}
    </div>
  </div>
  <div class="socials-track">
    {% for block in section.blocks %}
      {% if block.type == 'gallery_image' and block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 600 }}"
          class="social-img{% if block.settings.push_down %} push-down{% endif %}"
          alt="{{ block.settings.image.alt | default: 'Social Post' }}"
          {{ block.shopify_attributes }}
        >
      {% endif %}
    {% endfor %}
  </div>
</div>
<script src="{{ 'section-socials.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Socials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SEE YOU SOON!"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text",
      "default": "Follow @greentilesocialclub on Instagram to stay posted on when & where we're playing next"
    },
    {
      "type": "select",
      "id": "body_type_class",
      "label": "Body type class",
      "options": [
        { "value": "type-body1", "label": "Type body 1" },
        { "value": "type-body2", "label": "Type body 2" }
      ],
      "default": "type-body2"
    }
  ],
  "blocks": [
    {
      "type": "gallery_image",
      "name": "Gallery image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "checkbox",
          "id": "push_down",
          "label": "Push down",
          "default": false
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Socials",
      "blocks": [
        { "type": "gallery_image" },
        { "type": "gallery_image" },
        { "type": "gallery_image" },
        { "type": "gallery_image" },
        { "type": "gallery_image" }
      ]
    }
  ]
}
{% endschema %}
