{{ 'section-socials.css' | asset_url | stylesheet_tag }}

<div id="socials" class="socials-section">
  <div class="socials-header">
    <div class="type-subBold1 socials-subhead">{{ section.settings.subheading | default: 'hope we' }}</div>
    <div class="type-h1 animate-cascade">{{ section.settings.title | default: 'SEE YOU SOON!' }}</div>
    <div class="socials-icons">
      {%- for block in section.blocks -%}
        {%- if block.type == 'social_link' and block.settings.url != blank -%}
          {%- liquid
            assign icon_url = ''
            assign alt_text = block.settings.label | default: 'Social'
            case block.settings.platform
              when 'instagram'
                assign icon_url = 'Instagram_Glyph_White.svg' | asset_url
                assign alt_text = block.settings.label | default: 'Instagram'
              when 'tiktok'
                assign icon_url = 'tiktok-circle.svg' | asset_url
                assign alt_text = block.settings.label | default: 'TikTok'
              when 'discord'
                assign icon_url = 'discord-icon-svgrepo-com.svg' | asset_url
                assign alt_text = block.settings.label | default: 'Discord'
            endcase
            if block.settings.icon
              assign icon_url = block.settings.icon | image_url: width: 100
            endif
          -%}
          {%- liquid
            assign is_custom = false
            if block.settings.icon
              assign is_custom = true
            elsif block.settings.platform == 'custom'
              assign is_custom = true
            endif
          -%}
          {%- if icon_url != blank -%}
            <a class="icon-circle{% unless is_custom %} icon-{{ block.settings.platform }}{% endunless %}{% if is_custom %} icon-custom{% endif %}" href="{{ block.settings.url }}" target="_blank" rel="noopener" {{ block.shopify_attributes }}>
              <img src="{{ icon_url }}" alt="{{ alt_text | escape }}">
            </a>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="socials-track">
    {%- for block in section.blocks -%}
      {%- if block.type == 'image' -%}
        <img
          src="{{ block.settings.image | image_url: width: 800 }}"
          class="social-img"
          alt="{{ block.settings.image.alt | default: 'Social Post' | escape }}"
          loading="lazy"
          {{ block.shopify_attributes }}
        >
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<script src="{{ 'section-socials.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Socials",
  "tag": "div",
  "class": "socials-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "hope we"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "SEE YOU SOON!"
    }
  ],
  "blocks": [
    {
      "type": "social_link",
      "name": "Social link",
      "settings": [
        {
          "type": "select",
          "id": "platform",
          "label": "Platform",
          "options": [
            { "value": "instagram", "label": "Instagram" },
            { "value": "tiktok", "label": "TikTok" },
            { "value": "discord", "label": "Discord" },
            { "value": "custom", "label": "Custom" }
          ],
          "default": "instagram",
          "info": "Selects the built-in icon. Choose Custom to upload your own."
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Custom icon",
          "info": "Overrides the built-in platform icon"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "info": "Used as alt text for accessibility"
        }
      ]
    },
    {
      "type": "image",
      "name": "Gallery image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Socials",
      "blocks": [
        {
          "type": "social_link",
          "settings": {
            "platform": "instagram",
            "label": "Instagram"
          }
        },
        {
          "type": "social_link",
          "settings": {
            "platform": "tiktok",
            "label": "TikTok"
          }
        },
        {
          "type": "social_link",
          "settings": {
            "platform": "discord",
            "label": "Discord"
          }
        }
      ]
    }
  ]
}
{% endschema %}
