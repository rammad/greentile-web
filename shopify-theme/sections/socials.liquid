{{ 'section-socials.css' | asset_url | stylesheet_tag }}

<div id="socials" class="socials-section">
  <div class="socials-header">
    <div class="type-subBold1 socials-subhead">{{ section.settings.subheading | default: 'hope we' }}</div>
    <div class="type-h1 animate-cascade">{{ section.settings.title | default: 'SEE YOU SOON!' }}</div>
    <div class="socials-icons">
      {%- for i in (1..5) -%}
        {%- assign sp_platform_key = 'social_' | append: i | append: '_platform' -%}
        {%- assign sp_icon_key = 'social_' | append: i | append: '_icon' -%}
        {%- assign sp_url_key = 'social_' | append: i | append: '_url' -%}
        {%- assign sp_label_key = 'social_' | append: i | append: '_label' -%}
        {%- if settings[sp_url_key] != blank -%}
          {%- liquid
            assign icon_url = ''
            assign alt_text = settings[sp_label_key] | default: 'Social'
            case settings[sp_platform_key]
              when 'instagram'
                assign icon_url = 'Instagram_Glyph_White.svg' | asset_url
                assign alt_text = settings[sp_label_key] | default: 'Instagram'
              when 'tiktok'
                assign icon_url = 'tiktok-circle.svg' | asset_url
                assign alt_text = settings[sp_label_key] | default: 'TikTok'
              when 'discord'
                assign icon_url = 'discord-icon-svgrepo-com.svg' | asset_url
                assign alt_text = settings[sp_label_key] | default: 'Discord'
            endcase
            if settings[sp_icon_key]
              assign icon_url = settings[sp_icon_key] | image_url: width: 100
            endif
          -%}
          {%- liquid
            assign is_custom = false
            if settings[sp_icon_key]
              assign is_custom = true
            elsif settings[sp_platform_key] == 'custom'
              assign is_custom = true
            endif
          -%}
          {%- if icon_url != blank -%}
            <a class="icon-circle{% unless is_custom %} icon-{{ settings[sp_platform_key] }}{% endunless %}{% if is_custom %} icon-custom{% endif %}"
              href="{{ settings[sp_url_key] }}" target="_blank" rel="noopener"
              style="mask-image: url('{{ icon_url }}'); -webkit-mask-image: url('{{ icon_url }}');"
            >
              <img src="{{ icon_url }}" alt="{{ alt_text | escape }}">
            </a>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="socials-track">
    {%- for block in section.blocks -%}
      {%- if block.type == 'image' -%}
        <img
          src="{{ block.settings.image | image_url: width: 800 }}"
          class="social-img"
          alt="{{ block.settings.image.alt | default: 'Social Post' | escape }}"
          loading="lazy"
          {{ block.shopify_attributes }}
        >
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<script src="{{ 'section-socials.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Socials",
  "tag": "div",
  "class": "socials-section-wrapper",
  "settings": [
    {
      "type": "paragraph",
      "content": "Social links and icons are configured in Theme settings → Social links."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "hope we"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "SEE YOU SOON!"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Gallery image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Socials"
    }
  ]
}
{% endschema %}
