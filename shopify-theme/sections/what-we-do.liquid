{{ 'section-what-we-do.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign items = section.blocks | where: 'type', 'menu_item'
-%}

<section id="about" class="what-we-do"
  data-colors="{% render 'palette-color', source: section.settings.gradient_color_1_source, custom: section.settings.gradient_color_1 %}, {% render 'palette-color', source: section.settings.gradient_color_2_source, custom: section.settings.gradient_color_2 %}, {% render 'palette-color', source: section.settings.gradient_color_3_source, custom: section.settings.gradient_color_3 %}"
  data-colors-mobile="{% render 'palette-color', source: section.settings.gradient_color_1_mobile_source, custom: section.settings.gradient_color_1_mobile %}, {% render 'palette-color', source: section.settings.gradient_color_2_mobile_source, custom: section.settings.gradient_color_2_mobile %}, {% render 'palette-color', source: section.settings.gradient_color_3_mobile_source, custom: section.settings.gradient_color_3_mobile %}"
  data-edge="0"
  data-touch-speed="0.5"
>
  <div class="about-menu-persistent">
    <div class="menu-label text-mask">
      <span class="type-subBold1 text-reveal-inner">{{ section.settings.label | default: 'What We Do' }}</span>
    </div>
    <ul>
      {%- for block in items -%}
        <li class="menu-item type-h2" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          {{ block.settings.title }}
        </li>
      {%- endfor -%}
    </ul>
  </div>

  <div class="about-sticky-content">
    {%- for block in items -%}
      <div class="about-text-block" id="text-{{ forloop.index0 }}">
        <div class="about-content">
          <p class="type-body2">{{ block.settings.body }}</p>
          {%- if block.settings.cta_label != blank -%}
            {%- if block.settings.contact_topic != blank -%}
              <a href="#" class="cta-btn" data-contact-trigger data-contact-topic="{{ block.settings.contact_topic }}">
            {%- else -%}
              <a href="{{ block.settings.cta_url | default: '#' }}" class="cta-btn">
            {%- endif -%}
              <div class="ui-roll roll-hover">
                <span class="type-subRegular1 ui-roll-layer ui-roll-visible">{{ block.settings.cta_label }}</span>
                <span class="type-subRegular1 ui-roll-layer ui-roll-hidden">{{ block.settings.cta_label }}</span>
              </div>
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

  <div class="about-image-track">
    {%- for block in items -%}
      {%- assign g = forloop.index0 -%}
      {%- if block.settings.image_1 != blank -%}
        <img src="{{ block.settings.image_1 | image_url: width: 800 }}" alt="{{ block.settings.image_1.alt | default: '' }}" class="scatter-img" data-group="{{ g }}" loading="lazy">
      {%- endif -%}
      {%- if block.settings.image_2 != blank -%}
        <img src="{{ block.settings.image_2 | image_url: width: 800 }}" alt="{{ block.settings.image_2.alt | default: '' }}" class="scatter-img" data-group="{{ g }}" loading="lazy">
      {%- endif -%}
      {%- if block.settings.image_3 != blank -%}
        <img src="{{ block.settings.image_3 | image_url: width: 800 }}" alt="{{ block.settings.image_3.alt | default: '' }}" class="scatter-img" data-group="{{ g }}" loading="lazy">
      {%- endif -%}
      {%- if block.settings.image_4 != blank -%}
        <img src="{{ block.settings.image_4 | image_url: width: 800 }}" alt="{{ block.settings.image_4.alt | default: '' }}" class="scatter-img" data-group="{{ g }}" loading="lazy">
      {%- endif -%}
      {%- if block.settings.image_5 != blank -%}
        <img src="{{ block.settings.image_5 | image_url: width: 800 }}" alt="{{ block.settings.image_5.alt | default: '' }}" class="scatter-img" data-group="{{ g }}" loading="lazy">
      {%- endif -%}
      {%- if block.settings.image_6 != blank -%}
        <img src="{{ block.settings.image_6 | image_url: width: 800 }}" alt="{{ block.settings.image_6.alt | default: '' }}" class="scatter-img" data-group="{{ g }}" loading="lazy">
      {%- endif -%}
      {%- if block.settings.image_7 != blank -%}
        <img src="{{ block.settings.image_7 | image_url: width: 800 }}" alt="{{ block.settings.image_7.alt | default: '' }}" class="scatter-img" data-group="{{ g }}" loading="lazy">
      {%- endif -%}
      {%- if block.settings.image_8 != blank -%}
        <img src="{{ block.settings.image_8 | image_url: width: 800 }}" alt="{{ block.settings.image_8.alt | default: '' }}" class="scatter-img" data-group="{{ g }}" loading="lazy">
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<script src="{{ 'scatter-images.js' | asset_url }}" defer></script>
<script src="{{ 'section-what-we-do.js' | asset_url }}" defer></script>

