<section
  id="about"
  class="what-we-do"
  data-colors="{{ section.settings.gradient_color_1 }}, {{ section.settings.gradient_color_2 }}, {{ section.settings.gradient_color_3 }}"
  data-edge="{{ section.settings.gradient_edge }}"
>
  <div class="about-menu-persistent">
    <div class="menu-label text-mask">
      <span class="type-subBold1 text-reveal-inner">{{ section.settings.menu_label }}</span>
    </div>
    <ul>
      {% for block in section.blocks %}
        {% if block.type == 'menu_item' %}
          <li class="menu-item type-h2" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>{{ block.settings.title }}</li>
        {% endif %}
      {% endfor %}
    </ul>
  </div>

  <div class="about-sticky-content">
    {% for block in section.blocks %}
      {% if block.type == 'menu_item' %}
        <div class="about-text-block" id="text-{{ forloop.index0 }}">
          <div class="about-content">
            <p class="type-body1">{{ block.settings.body }}</p>
            {% if block.settings.cta_text != blank %}
              <a href="{{ block.settings.cta_url | default: '#' }}" class="cta-btn">
                <div class="ui-roll roll-hover">
                  <span class="type-subRegular1 ui-roll-layer ui-roll-visible">{{ block.settings.cta_text }}</span>
                  <span class="type-subRegular1 ui-roll-layer ui-roll-hidden">{{ block.settings.cta_text }}</span>
                </div>
              </a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="about-image-track">
    {% for block in section.blocks %}
      {% if block.type == 'menu_item' %}
        {% assign group_index = forloop.index0 %}
        {% if block.settings.image_1 %}
          <img src="{{ block.settings.image_1 | image_url: width: 800 }}" class="scatter-img" data-group="{{ group_index }}">
        {% endif %}
        {% if block.settings.image_2 %}
          <img src="{{ block.settings.image_2 | image_url: width: 800 }}" class="scatter-img" data-group="{{ group_index }}">
        {% endif %}
        {% if block.settings.image_3 %}
          <img src="{{ block.settings.image_3 | image_url: width: 800 }}" class="scatter-img" data-group="{{ group_index }}">
        {% endif %}
        {% if block.settings.image_4 %}
          <img src="{{ block.settings.image_4 | image_url: width: 800 }}" class="scatter-img" data-group="{{ group_index }}">
        {% endif %}
      {% endif %}
    {% endfor %}
  </div>
</section>
<script src="{{ 'section-what-we-do.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "What we do",
  "settings": [
    {
      "type": "text",
      "id": "menu_label",
      "label": "Menu label",
      "default": "What We Do"
    },
    {
      "type": "color",
      "id": "gradient_color_1",
      "label": "Gradient color 1",
      "default": "#FFFCFA"
    },
    {
      "type": "color",
      "id": "gradient_color_2",
      "label": "Gradient color 2",
      "default": "#dcf8dc"
    },
    {
      "type": "color",
      "id": "gradient_color_3",
      "label": "Gradient color 3",
      "default": "#FFFCFA"
    },
    {
      "type": "range",
      "id": "gradient_edge",
      "label": "Gradient edge",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 1
    }
  ],
  "blocks": [
    {
      "type": "menu_item",
      "name": "Menu item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Menu Item"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "Description text"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "CTA text",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "CTA URL"
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Image 1"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Image 2"
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Image 3"
        },
        {
          "type": "image_picker",
          "id": "image_4",
          "label": "Image 4"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "What we do",
      "blocks": [
        {
          "type": "menu_item",
          "settings": {
            "title": "Community Events",
            "body": "The heart of GTSC 💚 Every month, we host pop-up mahjong events to gather our growing community over games of Hong Kong mahjong.",
            "cta_text": "All Events"
          }
        },
        {
          "type": "menu_item",
          "settings": {
            "title": "Brand Partnerships",
            "body": "On occasion, we partner with values-aligned brands to amplify Chinese mahjong and culture on the national stage.",
            "cta_text": "Partner with us"
          }
        },
        {
          "type": "menu_item",
          "settings": {
            "title": "Corporate & Private Events",
            "body": "GTSC on your turf. We can bring our entire pop-up operation to birthdays, weddings, corporate headquarters, and more.",
            "cta_text": "book a private event"
          }
        },
        {
          "type": "menu_item",
          "settings": {
            "title": "Special Projects",
            "body": "Books, podcasts, merch, etc — we love making things that celebrate the community + culture behind Chinese mahjong.",
            "cta_text": "Collaborate with us"
          }
        }
      ]
    }
  ]
}
{% endschema %}
