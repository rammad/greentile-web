{{ 'section-about.css' | asset_url | stylesheet_tag }}

<section id="about" class="about section-spacer"
  data-colors="{% render 'palette-color', source: section.settings.gradient_color_1_source, custom: section.settings.gradient_color_1 %}, {% render 'palette-color', source: section.settings.gradient_color_2_source, custom: section.settings.gradient_color_2 %}, {% render 'palette-color', source: section.settings.gradient_color_3_source, custom: section.settings.gradient_color_3 %}"
  data-edge="0"
>
  <div class="about-inner">
    <div class="type-subBold1 about-subhead animate-line">{{ section.settings.subheading | default: 'manifesto' }}</div>
    <div class="about-text type-h1">{{ section.settings.body }}</div>

    <div class="about-images" hidden aria-hidden="true">
      {%- for block in section.blocks -%}
        {%- if block.type == 'inline_image' -%}
          {%- liquid
            assign img_pool = ''
            if block.settings.image
              assign img_pool = block.settings.image | image_url: width: 600
            endif
            if block.settings.image_2
              assign img_pool = img_pool | append: '|' | append: block.settings.image_2 | image_url: width: 600
            endif
            if block.settings.image_3
              assign img_pool = img_pool | append: '|' | append: block.settings.image_3 | image_url: width: 600
            endif
            if block.settings.image_4
              assign img_pool = img_pool | append: '|' | append: block.settings.image_4 | image_url: width: 600
            endif
          -%}
          <img
            src="{{ block.settings.image | image_url: width: 600 }}"
            class="about-inline-img"
            alt="{{ block.settings.image.alt | escape }}"
            data-word="{{ block.settings.word_position }}"
            data-images="{{ img_pool }}"
            loading="lazy"
            {{ block.shopify_attributes }}
          >
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<script src="{{ 'section-about.js' | asset_url }}" defer></script>

