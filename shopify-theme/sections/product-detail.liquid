{%- comment -%}
  Placeholder product detail page: content comes from section settings and blocks, not the
  Shopify product object yet.

  TODO: Wire this section to the Shopify product object (product.title, product.description,
  product.price, product.images, cart form) once sample product data is available.
{%- endcomment -%}

<section class="pdp-section">
  <div class="pdp-sticky-wrapper">
    <a href="{{ section.settings.back_url | default: '/pages/events' }}" class="back-arrow">
      <img src="{{ 'arrow-right.png' | asset_url }}" alt="Back to Events">
    </a>

    <div class="pdp-grid">
      <div class="pdp-image-col">
        <div class="pdp-image-track">
          {% for block in section.blocks %}
            {% if block.type == 'product_image' and block.settings.image %}
              <img src="{{ block.settings.image | image_url: width: 1200 }}" class="pdp-poster" alt="Event Poster" {{ block.shopify_attributes }}>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      <div class="pdp-info">
        <div class="pdp-meta-row text-mask">
          <span class="type-subBold2 text-reveal-inner">{{ section.settings.date_line }}</span>
        </div>
        <h1 class="type-h3 animate-cascade pdp-hero-title">{{ section.settings.title }}</h1>
        <div class="pdp-meta-row text-mask">
          <span class="type-subBold2 text-reveal-inner">{{ section.settings.location }}</span>
        </div>
        <div class="pdp-meta-row">
          {% for block in section.blocks %}
            {% if block.type == 'tag' %}
              <div class="pdp-tag" {{ block.shopify_attributes }}>
                <span class="type-subRegular2 text-reveal-inner">{{ block.settings.text }}</span>
              </div>
            {% endif %}
          {% endfor %}
        </div>
        <div class="pdp-desc-wrapper">
          <div class="pdp-desc type-body1">{{ section.settings.description }}</div>
        </div>
        <div class="ticket-actions">
          <div class="max-qty-label pdp-tag type-subRegular2" id="max-qty-msg">Max Limit Reached</div>
          <div class="qty-wrapper">
            <div class="qty-selector">
              <button class="qty-btn type-subRegular1" onclick="updateQty(-1)">&minus;</button>
              <span class="qty-val type-subRegular1" id="ticket-qty">1</span>
              <button class="qty-btn type-subRegular1" onclick="updateQty(1)">&plus;</button>
            </div>
          </div>
          <a href="#" class="cta-btn buy-button-override">
            <div class="ui-roll roll-hover">
              <span class="type-subRegular1 ui-roll-layer ui-roll-visible">
                <span>{{ section.settings.price }}</span><span>&ndash;</span><span>{{ section.settings.buy_text }}</span>
              </span>
              <span class="type-subRegular1 ui-roll-layer ui-roll-hidden">
                <span>{{ section.settings.price }}</span><span>&ndash;</span><span>{{ section.settings.buy_text }}</span>
              </span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="{{ 'section-product.js' | asset_url }}"></script>

{% schema %}
{
  "name": "Product Detail",
  "max_blocks": 20,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "green tile new year 2026"
    },
    {
      "type": "text",
      "id": "date_line",
      "label": "Date line",
      "default": "Sunday, February 22 - 12PM - 6PM"
    },
    {
      "type": "text",
      "id": "location",
      "label": "Location",
      "default": "Industry City's 52A, 33 35th St, Brooklyn, NY"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Join us for mahjong, food, drinks, and music. Details and ticketing will connect to Shopify products later.</p>"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price display",
      "default": "$25"
    },
    {
      "type": "text",
      "id": "buy_text",
      "label": "Buy button text",
      "default": "Buy Now"
    },
    {
      "type": "url",
      "id": "back_url",
      "label": "Back link URL"
    }
  ],
  "blocks": [
    {
      "type": "product_image",
      "name": "Product image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    },
    {
      "type": "tag",
      "name": "Tag",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Tag"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Detail",
      "blocks": [
        { "type": "product_image", "settings": {} },
        { "type": "product_image", "settings": {} },
        { "type": "product_image", "settings": {} },
        { "type": "product_image", "settings": {} },
        {
          "type": "tag",
          "settings": { "text": "3 Point Hong Kong Style" }
        },
        {
          "type": "tag",
          "settings": { "text": "Non Points" }
        },
        {
          "type": "tag",
          "settings": { "text": "Vendors" }
        },
        {
          "type": "tag",
          "settings": { "text": "Food and Drinks" }
        },
        {
          "type": "tag",
          "settings": { "text": "Live DJ" }
        }
      ]
    }
  ]
}
{% endschema %}
