{{ 'section-mission.css' | asset_url | stylesheet_tag }}

<section id="mission" class="mission-section"
  data-colors="{% render 'palette-color', source: section.settings.gradient_color_1_source, custom: section.settings.gradient_color_1 %}, {% render 'palette-color', source: section.settings.gradient_color_2_source, custom: section.settings.gradient_color_2 %}, {% render 'palette-color', source: section.settings.gradient_color_3_source, custom: section.settings.gradient_color_3 %}"
  data-touch-speed="1.0"
>
  <div class="text-mask">
    <span class="type-subBold1 text-reveal-inner">{{ section.settings.label | default: 'mission' }}</span>
  </div>

  <div class="mission-lines">
    {%- for block in section.blocks -%}
      {%- if block.type == 'line' -%}
        <h1 class="type-display-hero animate-line" {{ block.shopify_attributes }}>{{ block.settings.text }}</h1>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<script src="{{ 'section-mission.js' | asset_url }}" defer></script>

