{%- comment -%}
  Resolve featured product:
    1. Manual product picker in settings (explicit override)
    2. First active product tagged with the configured featured tag
{%- endcomment -%}
{%- assign featured_tag = section.settings.featured_tag | default: 'featured' | downcase -%}
{%- assign feat_product = nil -%}

{%- if section.settings.product != blank -%}
  {%- assign feat_product = all_products[section.settings.product] -%}
{%- else -%}
  {%- for product in collections.all.products -%}
    {%- for tag in product.tags -%}
      {%- assign tag_lower = tag | downcase -%}
      {%- if tag_lower == featured_tag -%}
        {%- assign feat_product = product -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if feat_product -%}{%- break -%}{%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- if feat_product or section.settings.poster_image -%}
  {{ 'section-featured.css' | asset_url | stylesheet_tag }}

  <section id="featured" class="featured-section"
    data-colors="{{ section.settings.gradient_color_1 | default: '#FFFCFA' }}, {{ section.settings.gradient_color_2 | default: '#C1FEC1' }}, {{ section.settings.gradient_color_3 | default: '#FFFCFA' }}"
    data-edge="0"
  >
    <div class="featured-bg-wrap">
      {%- if section.settings.background_image -%}
        <img class="featured-bg-img"
          src="{{ section.settings.background_image | image_url: width: 1920 }}"
          alt="" aria-hidden="true" loading="lazy"
        >
      {%- elsif feat_product and feat_product.images.size > 1 -%}
        <img class="featured-bg-img"
          src="{{ feat_product.images[1] | image_url: width: 1920 }}"
          alt="" aria-hidden="true" loading="lazy"
        >
      {%- elsif feat_product and feat_product.featured_image -%}
        <img class="featured-bg-img"
          src="{{ feat_product.featured_image | image_url: width: 1920 }}"
          alt="" aria-hidden="true" loading="lazy"
        >
      {%- endif -%}
    </div>

    <div class="featured-frame">
      <div class="featured-marquee-layer" aria-hidden="true">
        <div class="featured-marquee-track">
          {%- for i in (1..20) -%}
            <span class="featured-marquee-item type-h1">{{ section.settings.marquee_text | default: 'FEATURING' }}</span>
          {%- endfor -%}
        </div>
      </div>

      <div class="featured-poster-wrap">
        {%- if section.settings.poster_image -%}
          <img src="{{ section.settings.poster_image | image_url: width: 1920 }}"
            class="featured-img"
            alt="{{ section.settings.poster_alt | default: 'Featured Event' }}"
            loading="lazy"
          >
        {%- elsif feat_product and feat_product.featured_image -%}
          <a href="{{ feat_product.url }}">
            <img src="{{ feat_product.featured_image | image_url: width: 1920 }}"
              class="featured-img"
              alt="{{ feat_product.title | escape }}"
              loading="lazy"
            >
          </a>
        {%- endif -%}
      </div>

      <div class="featured-marquee-layer featured-marquee-bottom" aria-hidden="true">
        <div class="featured-marquee-track marquee-reverse">
          {%- for i in (1..20) -%}
            <span class="featured-marquee-item type-h1">{{ section.settings.marquee_text | default: 'FEATURING' }}</span>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </section>

  <script src="{{ 'section-featured.js' | asset_url }}" defer></script>
{%- endif -%}

{% schema %}
{
  "name": "Featured event",
  "tag": "div",
  "class": "featured-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "featured_tag",
      "label": "Featured tag",
      "default": "featured",
      "info": "The product tag used to identify the featured event. First matching active product is shown."
    },
    {
      "type": "product",
      "id": "product",
      "label": "Manual product override",
      "info": "Overrides auto-detection. Leave empty to auto-pick the product tagged above."
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Poster image (manual)",
      "info": "Overrides product image if set"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image (manual)",
      "info": "Blurred background. Uses product's 2nd image by default, falls back to featured image."
    },
    {
      "type": "text",
      "id": "poster_alt",
      "label": "Poster alt text"
    },
    {
      "type": "text",
      "id": "marquee_text",
      "label": "Marquee text",
      "default": "FEATURING"
    },
    {
      "type": "header",
      "content": "Section gradient"
    },
    {
      "type": "color",
      "id": "gradient_color_1",
      "label": "Gradient color 1",
      "default": "#FFFCFA"
    },
    {
      "type": "color",
      "id": "gradient_color_2",
      "label": "Gradient color 2",
      "default": "#C1FEC1"
    },
    {
      "type": "color",
      "id": "gradient_color_3",
      "label": "Gradient color 3",
      "default": "#FFFCFA"
    }
  ],
  "presets": [
    {
      "name": "Featured event"
    }
  ]
}
{% endschema %}
