{{ 'section-calendar.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign evt_ns = settings.event_metafield_namespace | default: 'event_ticketing'
  assign evt_key = settings.event_metafield_key | default: 'event_v2'

  assign cal_collection = section.settings.collection

  assign current_month = 'now' | date: '%m' | plus: 0
  assign current_year = 'now' | date: '%Y'

  if current_month >= 3 and current_month <= 5
    assign season_label = 'Spring'
    assign season_start = current_year | append: '-03-01'
    assign season_end = current_year | append: '-05-31'
    assign season_months = 'March,April,May'
  elsif current_month >= 6 and current_month <= 8
    assign season_label = 'Summer'
    assign season_start = current_year | append: '-06-01'
    assign season_end = current_year | append: '-08-31'
    assign season_months = 'June,July,August'
  elsif current_month >= 9 and current_month <= 11
    assign season_label = 'Fall'
    assign season_start = current_year | append: '-09-01'
    assign season_end = current_year | append: '-11-30'
    assign season_months = 'September,October,November'
  else
    assign season_label = 'Winter'
    assign season_months = 'December,January,February'
    if current_month == 12
      assign season_start = current_year | append: '-12-01'
      assign next_year = current_year | plus: 1
      assign season_end = next_year | append: '-02-28'
    else
      assign prev_year = current_year | minus: 1
      assign season_start = prev_year | append: '-12-01'
      assign season_end = current_year | append: '-02-28'
    endif
  endif

  assign season_months_arr = season_months | split: ','

  assign auto_title = season_label | append: ' Calendar ' | append: current_year
  assign page_title = section.settings.title | default: auto_title

  if section.settings.cs_shape_1
    assign cs1_url = section.settings.cs_shape_1 | image_url: width: 400
  else
    assign cs1_url = 'sticker-cs-shape-1-blank.svg' | asset_url
  endif
  if section.settings.cs_shape_2
    assign cs2_url = section.settings.cs_shape_2 | image_url: width: 400
  else
    assign cs2_url = ''
  endif
  if section.settings.cs_shape_3
    assign cs3_url = section.settings.cs_shape_3 | image_url: width: 400
  else
    assign cs3_url = 'sticker-cs-shape-3-blank.svg' | asset_url
  endif
  if section.settings.cs_shape_4
    assign cs4_url = section.settings.cs_shape_4 | image_url: width: 400
  else
    assign cs4_url = 'sticker-cs-shape-4-blank.svg' | asset_url
  endif
  if section.settings.cs_text
    assign cs_text_url = section.settings.cs_text | image_url: width: 400
  else
    assign cs_text_url = 'sticker-cs-text-white.svg' | asset_url
  endif

  if section.settings.so_shape_1
    assign so1_url = section.settings.so_shape_1 | image_url: width: 400
  else
    assign so1_url = 'sticker-so-shape-1-blank.svg' | asset_url
  endif
  if section.settings.so_shape_2
    assign so2_url = section.settings.so_shape_2 | image_url: width: 400
  else
    assign so2_url = 'sticker-so-shape-2-blank.svg' | asset_url
  endif
  if section.settings.so_shape_3
    assign so3_url = section.settings.so_shape_3 | image_url: width: 400
  else
    assign so3_url = 'sticker-so-shape-3-blank.svg' | asset_url
  endif
  if section.settings.so_shape_4
    assign so4_url = section.settings.so_shape_4 | image_url: width: 400
  else
    assign so4_url = 'sticker-so-shape-4-blank.svg' | asset_url
  endif
  if section.settings.so_text
    assign so_text_url = section.settings.so_text | image_url: width: 400
  else
    assign so_text_url = 'sticker-so-text-white.svg' | asset_url
  endif

  assign cs_color = section.settings.cs_color | default: '#87A587'
  assign so_color = section.settings.so_color | default: '#000000'
  assign placeholder_color = section.settings.placeholder_color | default: '#B7C9B7'
  assign placeholder_font = section.settings.placeholder_font_color | default: '#87A587'
-%}

<section class="calendar-page" id="cal-page-container"
  style="--placeholder-bg: {{ placeholder_color }}; --placeholder-font: {{ placeholder_font }}"
  data-colors="{% render 'palette-color', source: section.settings.gradient_color_1_source, custom: section.settings.gradient_color_1 %}, {% render 'palette-color', source: section.settings.gradient_color_2_source, custom: section.settings.gradient_color_2 %}, {% render 'palette-color', source: section.settings.gradient_color_3_source, custom: section.settings.gradient_color_3 %}"
  data-edge="0"
  data-sticker-cs-blank1="{{ cs1_url }}"
  data-sticker-cs-blank2="{{ cs2_url }}"
  data-sticker-cs-blank3="{{ cs3_url }}"
  data-sticker-cs-blank4="{{ cs4_url }}"
  data-sticker-cs-text="{{ cs_text_url }}"
  data-sticker-cs-color="{{ cs_color }}"
  data-sticker-so-blank1="{{ so1_url }}"
  data-sticker-so-blank2="{{ so2_url }}"
  data-sticker-so-blank3="{{ so3_url }}"
  data-sticker-so-blank4="{{ so4_url }}"
  data-sticker-so-text="{{ so_text_url }}"
  data-sticker-so-color="{{ so_color }}"
>
  <div class="calendar-header">
    <h1 class="type-display-hero animate-cascade desktop-only">
      {{ page_title }}
    </h1>
    <div class="calendar-title-mobile mobile-only">
      {%- assign title_words = page_title | split: ' ' -%}
      {%- for word in title_words -%}
        <div class="type-display-hero fit-text" data-fit-managed>{{ word }}</div>
      {%- endfor -%}
    </div>

    <div class="calendar-controls">
      <div class="filters-list">
        <div class="text-mask">
          <span class="type-subRegular1 text-reveal-inner">{{ 'events.filters' | t }}</span>
        </div>
        <button class="filter-btn type-subRegular1 ui-roll roll-hover active" data-filter="all">
          <span class="ui-roll-layer ui-roll-visible">{{ 'events.all' | t }}</span>
          <span class="ui-roll-layer ui-roll-hidden">{{ 'events.all' | t }}</span>
        </button>
        {%- for month_name in season_months_arr -%}
          <button class="filter-btn type-subRegular1 ui-roll roll-hover" data-filter="{{ month_name | downcase }}">
            <span class="ui-roll-layer ui-roll-visible">{{ month_name }}</span>
            <span class="ui-roll-layer ui-roll-hidden">{{ month_name }}</span>
          </button>
        {%- endfor -%}
      </div>

      <div class="filters-list">
        <button class="view-btn type-subRegular1 ui-roll roll-hover active" id="btn-list">
          <span class="ui-roll-layer ui-roll-visible">{{ 'events.list' | t }}</span>
          <span class="ui-roll-layer ui-roll-hidden">{{ 'events.list' | t }}</span>
        </button>
        <span class="divider">/</span>
        <button class="view-btn type-subRegular1 ui-roll roll-hover" id="btn-grid">
          <span class="ui-roll-layer ui-roll-visible">{{ 'events.grid' | t }}</span>
          <span class="ui-roll-layer ui-roll-hidden">{{ 'events.grid' | t }}</span>
        </button>
        <span class="divider">/</span>
        <a href="{{ section.settings.archives_url | default: '#' }}" class="filter-btn type-subRegular1 ui-roll roll-hover">
          <span class="ui-roll-layer ui-roll-visible">{{ 'events.archives' | t }}</span>
          <span class="ui-roll-layer ui-roll-hidden">{{ 'events.archives' | t }}</span>
        </a>
      </div>
    </div>
  </div>

  <div class="calendar-body">
    <div class="calendar-interface-wrapper">
      <div class="calendar-list" data-lenis-prevent>
        {%- if cal_collection != blank -%}
          {%- for product in collections[cal_collection].products -%}
            {%- liquid
              assign ev = product.metafields[evt_ns][evt_key].value
              assign event_date_str = nil

              if ev
                assign event_date_str = ev.starts_at | date: '%Y-%m-%d'
                assign date_display = ev.starts_at | date: '%m.%d'
                assign event_venue_name = ev.venue.name
              else
                assign date_display = nil
                assign event_venue_name = nil
              endif

              assign in_season = false
              if event_date_str == nil
                assign in_season = true
              elsif event_date_str >= season_start and event_date_str <= season_end
                assign in_season = true
              endif
            -%}

            {%- if in_season -%}
              {%- liquid
                assign row_status = ''
                if product.tags contains 'upcoming'
                  assign row_status = 'coming-soon'
                elsif product.available == false
                  assign row_status = 'sold-out'
                endif
              -%}
              {%- if row_status == 'coming-soon' -%}
                <div class="calendar-row calendar-row--upcoming"
                  data-month="{{ date_display | split: '.' | first }}"
                  data-img="{{ product.featured_image | image_url: width: 800 }}"
                  data-title="{{ product.title | escape }}"
                  {%- if ev and ev.venue %} data-venue="{{ event_venue_name | escape }}"{% endif -%}
                  data-status="coming-soon"
                >
                  <span class="cal-date type-h2">{{ date_display | default: '—' }}</span>
                  <span class="cal-name type-h2">{{ product.title }}</span>
                </div>
              {%- else -%}
                <a href="{{ product.url }}" class="calendar-row"
                  data-month="{{ date_display | split: '.' | first }}"
                  data-img="{{ product.featured_image | image_url: width: 800 }}"
                  data-title="{{ product.title | escape }}"
                  {%- if ev and ev.venue %} data-venue="{{ event_venue_name | escape }}"{% endif -%}
                  {%- if row_status != blank %} data-status="{{ row_status }}"{% endif -%}
                >
                  <span class="cal-date type-h2">{{ date_display | default: '—' }}</span>
                  <span class="cal-name type-h2">{{ product.title }}</span>
                </a>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}

      </div>

      <div class="calendar-poster-wrapper" id="poster-wrapper">
        <img src="" alt="{{ section.settings.poster_alt | default: 'Event Poster' }}" class="calendar-poster-img" id="poster-img">
        <div class="status-badge badge-soon" id="status-soon"></div>
        <div class="status-badge badge-sold" id="status-sold"></div>
      </div>
    </div>

    <div id="dynamic-grid-container" class="calendar-grid-packed"></div>
  </div>
  <div class="calendar-coming-soon"><span class="type-h2">{{ section.settings.empty_message | default: 'more events coming soon!' }}</span></div>
</section>

<script src="{{ 'section-calendar.js' | asset_url }}" defer></script>

