{{ 'section-calendar.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign evt_ns = settings.event_metafield_namespace | default: 'event_ticketing'
  assign evt_key = settings.event_metafield_key | default: 'event_v2'

  assign cal_collection = section.settings.collection
  if cal_collection != blank
    assign event_source = collections[cal_collection].products
  else
    assign event_source = collections.all.products
  endif

  assign manual_filters = section.blocks | where: 'type', 'month_filter'

  assign current_month = 'now' | date: '%m' | plus: 0
  assign current_year = 'now' | date: '%Y'

  if current_month >= 3 and current_month <= 5
    assign season_label = 'Spring'
    assign season_start = current_year | append: '-03-01'
    assign season_end = current_year | append: '-05-31'
  elsif current_month >= 6 and current_month <= 8
    assign season_label = 'Summer'
    assign season_start = current_year | append: '-06-01'
    assign season_end = current_year | append: '-08-31'
  elsif current_month >= 9 and current_month <= 11
    assign season_label = 'Fall'
    assign season_start = current_year | append: '-09-01'
    assign season_end = current_year | append: '-11-30'
  else
    assign season_label = 'Winter'
    if current_month == 12
      assign season_start = current_year | append: '-12-01'
      assign next_year = current_year | plus: 1
      assign season_end = next_year | append: '-02-28'
    else
      assign prev_year = current_year | minus: 1
      assign season_start = prev_year | append: '-12-01'
      assign season_end = current_year | append: '-02-28'
    endif
  endif

  assign auto_title = season_label | append: ' Calendar ' | append: current_year
  assign page_title = section.settings.title | default: auto_title
-%}

<section class="calendar-page" id="cal-page-container"
  data-colors="{{ section.settings.gradient_colors | default: '#FFFCFA, #D6FED6, #FFFCFA' }}"
  data-edge="0"
  data-sticker-cs-blank-1="{{ 'sticker-cs-shape-1-blank.svg' | asset_url }}"
  data-sticker-cs-blank-3="{{ 'sticker-cs-shape-3-blank.svg' | asset_url }}"
  data-sticker-cs-blank-4="{{ 'sticker-cs-shape-4-blank.svg' | asset_url }}"
  data-sticker-cs-text="{{ 'sticker-cs-text-white.svg' | asset_url }}"
  data-sticker-so-blank-1="{{ 'sticker-so-shape-1-blank.svg' | asset_url }}"
  data-sticker-so-blank-2="{{ 'sticker-so-shape-2-blank.svg' | asset_url }}"
  data-sticker-so-blank-3="{{ 'sticker-so-shape-3-blank.svg' | asset_url }}"
  data-sticker-so-blank-4="{{ 'sticker-so-shape-4-blank.svg' | asset_url }}"
  data-sticker-so-text="{{ 'sticker-so-text-white.svg' | asset_url }}"
>
  <div class="calendar-header">
    <h1 class="type-display-hero animate-cascade desktop-only">
      {{ page_title }}
    </h1>
    <div class="calendar-title-mobile mobile-only">
      {%- assign title_words = page_title | split: ' ' -%}
      {%- assign first_word = title_words | first -%}
      {%- assign rest = '' -%}
      {%- for word in title_words -%}
        {%- unless forloop.first -%}
          {%- if rest == '' -%}
            {%- assign rest = word -%}
          {%- else -%}
            {%- assign rest = rest | append: ' ' | append: word -%}
          {%- endif -%}
        {%- endunless -%}
      {%- endfor -%}
      <div class="type-display-hero fit-text" data-fit-managed>{{ first_word }}</div>
      <div class="type-display-hero fit-text" data-fit-managed>{{ rest }}</div>
    </div>

    <div class="calendar-controls">
      <div class="filters-list">
        <div class="text-mask">
          <span class="type-subRegular1 text-reveal-inner">{{ 'events.filters' | t }}</span>
        </div>
        <button class="filter-btn type-subRegular1 ui-roll roll-hover active">
          <span class="ui-roll-layer ui-roll-visible">{{ 'events.all' | t }}</span>
          <span class="ui-roll-layer ui-roll-hidden">{{ 'events.all' | t }}</span>
        </button>
        {%- for block in manual_filters -%}
          <button class="filter-btn type-subRegular1 ui-roll roll-hover" {{ block.shopify_attributes }}>
            <span class="ui-roll-layer ui-roll-visible">{{ block.settings.label }}</span>
            <span class="ui-roll-layer ui-roll-hidden">{{ block.settings.label }}</span>
          </button>
        {%- endfor -%}
      </div>

      <div class="filters-list">
        <button class="view-btn type-subRegular1 ui-roll roll-hover active" id="btn-list">
          <span class="ui-roll-layer ui-roll-visible">{{ 'events.list' | t }}</span>
          <span class="ui-roll-layer ui-roll-hidden">{{ 'events.list' | t }}</span>
        </button>
        <span class="divider">/</span>
        <button class="view-btn type-subRegular1 ui-roll roll-hover" id="btn-grid">
          <span class="ui-roll-layer ui-roll-visible">{{ 'events.grid' | t }}</span>
          <span class="ui-roll-layer ui-roll-hidden">{{ 'events.grid' | t }}</span>
        </button>
        <span class="divider">/</span>
        <a href="{{ section.settings.archives_url | default: '#' }}" class="filter-btn type-subRegular1 ui-roll roll-hover">
          <span class="ui-roll-layer ui-roll-visible">{{ 'events.archives' | t }}</span>
          <span class="ui-roll-layer ui-roll-hidden">{{ 'events.archives' | t }}</span>
        </a>
      </div>
    </div>
  </div>

  <div class="calendar-body">
    <div class="calendar-interface-wrapper">
      <div class="calendar-list" data-lenis-prevent>
        {%- if event_source.size > 0 -%}
          {%- for product in event_source -%}
            {%- liquid
              assign ev = product.metafields[evt_ns][evt_key].value
              assign event_date_str = nil

              if ev
                assign event_date_str = ev.starts_at | date: '%Y-%m-%d'
                assign date_display = ev.starts_at | date: '%m.%d'
                assign event_venue_name = ev.venue.name
              else
                assign date_display = nil
                assign event_venue_name = nil
              endif

              assign in_season = false
              if event_date_str == nil
                assign in_season = true
              elsif event_date_str >= season_start and event_date_str <= season_end
                assign in_season = true
              endif
            -%}

            {%- if in_season -%}
              {%- liquid
                assign row_status = ''
                if product.tags contains 'upcoming'
                  assign row_status = 'coming-soon'
                elsif product.available == false
                  assign row_status = 'sold-out'
                endif
              -%}
              {%- if row_status == 'coming-soon' -%}
                <div class="calendar-row calendar-row--upcoming"
                  data-img="{{ product.featured_image | image_url: width: 800 }}"
                  data-title="{{ product.title | escape }}"
                  {%- if ev and ev.venue %} data-venue="{{ event_venue_name | escape }}"{% endif -%}
                  data-status="coming-soon"
                >
                  <span class="cal-date type-h2">{{ date_display | default: '—' }}</span>
                  <span class="cal-name type-h2">{{ product.title }}</span>
                  <span class="cal-status type-subRegular2">Upcoming</span>
                </div>
              {%- else -%}
                <a href="{{ product.url }}" class="calendar-row"
                  data-img="{{ product.featured_image | image_url: width: 800 }}"
                  data-title="{{ product.title | escape }}"
                  {%- if ev and ev.venue %} data-venue="{{ event_venue_name | escape }}"{% endif -%}
                  {%- if row_status != blank %} data-status="{{ row_status }}"{% endif -%}
                >
                  <span class="cal-date type-h2">{{ date_display | default: '—' }}</span>
                  <span class="cal-name type-h2">{{ product.title }}</span>
                  {%- if row_status == 'sold-out' -%}
                    <span class="cal-status type-subRegular2">Sold Out</span>
                  {%- endif -%}
                </a>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'event_row' -%}
              <a href="{{ block.settings.url | default: '#' }}" class="calendar-row"
                data-img="{% if block.settings.poster %}{{ block.settings.poster | image_url: width: 800 }}{% endif %}"
                data-title="{{ block.settings.title | escape }}"
                {% if block.settings.status != blank %}data-status="{{ block.settings.status }}"{% endif %}
                {{ block.shopify_attributes }}
              >
                <span class="cal-date type-h2">{{ block.settings.date }}</span>
                <span class="cal-name type-h2">{{ block.settings.title }}</span>
              </a>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>

      <div class="calendar-poster-wrapper" id="poster-wrapper">
        <img src="" alt="Event Poster" class="calendar-poster-img" id="poster-img">
        <div class="status-badge badge-soon" id="status-soon"></div>
        <div class="status-badge badge-sold" id="status-sold"></div>
      </div>
    </div>

    <div id="dynamic-grid-container" class="calendar-grid-packed"></div>
  </div>
</section>

<script src="{{ 'section-calendar.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Event calendar",
  "tag": "div",
  "class": "calendar-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Page title override",
      "info": "Leave empty to auto-generate from current season (e.g. 'Spring Calendar 2026')"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Events collection (optional)",
      "info": "Leave empty to pull from all active products. Only events within the current season are shown."
    },
    {
      "type": "url",
      "id": "archives_url",
      "label": "Archives page URL"
    },
    {
      "type": "text",
      "id": "gradient_colors",
      "label": "Section gradient colors",
      "default": "#FFFCFA, #D6FED6, #FFFCFA"
    }
  ],
  "blocks": [
    {
      "type": "month_filter",
      "name": "Month filter",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Month label",
          "default": "March"
        }
      ]
    },
    {
      "type": "event_row",
      "name": "Event (manual)",
      "settings": [
        {
          "type": "text",
          "id": "date",
          "label": "Date display",
          "default": "03.07",
          "info": "Format: MM.DD"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Event title",
          "default": "Event Name"
        },
        {
          "type": "image_picker",
          "id": "poster",
          "label": "Event poster"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Event link"
        },
        {
          "type": "select",
          "id": "status",
          "label": "Status",
          "options": [
            { "value": "", "label": "Available" },
            { "value": "coming-soon", "label": "Coming Soon" },
            { "value": "sold-out", "label": "Sold Out" }
          ],
          "default": ""
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Event calendar",
      "blocks": [
        { "type": "month_filter", "settings": { "label": "March" } },
        { "type": "month_filter", "settings": { "label": "April" } },
        { "type": "month_filter", "settings": { "label": "May" } }
      ]
    }
  ]
}
{% endschema %}
