<section
  id="events"
  class="events-section sticky-track"
  data-colors="{{ section.settings.gradient_color_1 }}, {{ section.settings.gradient_color_2 }}, {{ section.settings.gradient_color_3 }}"
  data-edge="{{ section.settings.gradient_edge }}"
>
  <div class="events-sticky">
    <div class="events-sticky-inner">
      <div class="events-title-wrap">
        <h2 id="event-title" class="type-display-hero fit-text" data-fit-managed="true">{{ section.settings.title }}</h2>
      </div>
      <div class="events-content">
        <div class="events-grid">
          {% for block in section.blocks %}
            {% if block.type == 'event_card' and block.settings.image %}
              <div class="event-card" {{ block.shopify_attributes }}>
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  class="event-poster"
                  alt="{{ block.settings.image.alt | default: 'Event' }}"
                >
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      <div class="events-content-footer">
        <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="cta-btn">
          <div class="ui-roll roll-hover">
            <span class="type-subRegular1 ui-roll-layer ui-roll-visible">{{ section.settings.cta_text }}</span>
            <span class="type-subRegular1 ui-roll-layer ui-roll-hidden">{{ section.settings.cta_text }}</span>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>
<script src="{{ 'section-events.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Events preview",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "upcoming events"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "Browse All Events"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    },
    {
      "type": "color",
      "id": "gradient_color_1",
      "label": "Gradient color 1",
      "default": "#FFFCFA"
    },
    {
      "type": "color",
      "id": "gradient_color_2",
      "label": "Gradient color 2",
      "default": "#D6FED6"
    },
    {
      "type": "color",
      "id": "gradient_color_3",
      "label": "Gradient color 3",
      "default": "#FFFCFA"
    },
    {
      "type": "range",
      "id": "gradient_edge",
      "label": "Gradient edge",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "event_card",
      "name": "Event card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Events preview",
      "blocks": [
        { "type": "event_card" },
        { "type": "event_card" },
        { "type": "event_card" },
        { "type": "event_card" }
      ]
    }
  ]
}
{% endschema %}
