{{ 'section-calendar.css' | asset_url | stylesheet_tag }}
{{ 'section-archives.css' | asset_url | stylesheet_tag }}

<style>html, body { overflow: auto !important; height: auto !important; }</style>

{%- liquid
  assign evt_ns = settings.event_metafield_namespace | default: 'event_ticketing'
  assign evt_key = settings.event_metafield_key | default: 'event_v2'

  assign archive_collection = section.settings.collection
  if archive_collection != blank
    assign archive_source = collections[archive_collection].products
  else
    assign archive_source = collections.all.products
  endif

  assign current_month = 'now' | date: '%m' | plus: 0
  assign current_year = 'now' | date: '%Y'

  if current_month >= 3 and current_month <= 5
    assign season_start = current_year | append: '-03-01'
  elsif current_month >= 6 and current_month <= 8
    assign season_start = current_year | append: '-06-01'
  elsif current_month >= 9 and current_month <= 11
    assign season_start = current_year | append: '-09-01'
  else
    if current_month == 12
      assign season_start = current_year | append: '-12-01'
    else
      assign prev_year = current_year | minus: 1
      assign season_start = prev_year | append: '-12-01'
    endif
  endif
-%}

<section class="archives-page"
  data-colors="{% render 'palette-color', source: section.settings.gradient_color_1_source, custom: section.settings.gradient_color_1 %}, {% render 'palette-color', source: section.settings.gradient_color_2_source, custom: section.settings.gradient_color_2 %}, {% render 'palette-color', source: section.settings.gradient_color_3_source, custom: section.settings.gradient_color_3 %}"
  data-edge="0"
>
  <div class="archives-header desktop-only">
    <h1 class="archives-title animate-cascade">{{ section.settings.title | default: 'Event Archives' }}</h1>
  </div>
  <div class="archives-title-mobile mobile-only">
    {%- assign title_words = section.settings.title | default: 'Event Archives' | split: ' ' -%}
    {%- for word in title_words -%}
      <div class="type-display-hero fit-text" data-fit-managed>{{ word }}</div>
    {%- endfor -%}
  </div>

  <div id="dynamic-archive-container">
    {%- assign archive_count = 0 -%}
    {%- if archive_source.size > 0 -%}
      {%- for product in archive_source -%}
        {%- liquid
          assign ev = product.metafields[evt_ns][evt_key].value
          assign event_date_str = nil
          assign month_label = nil

          if ev
            assign event_date_str = ev.starts_at | date: '%Y-%m-%d'
            assign month_label = ev.starts_at | date: '%B %Y'
          endif

          assign is_archive = false
          if event_date_str and event_date_str < season_start
            assign is_archive = true
          endif
        -%}
        {%- if is_archive -%}
          <a href="{{ product.url }}" class="archive-cell" data-month="{{ month_label | default: 'Undated' }}">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 600 }}" class="archive-poster" loading="lazy" alt="{{ product.title | escape }}">
            {%- endif -%}
          </a>
          {%- assign archive_count = archive_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}

    {%- comment -%} Manual block fallback if no auto-archives found {%- endcomment -%}
    {%- if archive_count == 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'archive_event' -%}
          <a href="{{ block.settings.url | default: '#' }}" class="archive-cell" data-month="{{ block.settings.month }}" {{ block.shopify_attributes }}>
            {%- if block.settings.poster -%}
              <img src="{{ block.settings.poster | image_url: width: 600 }}" class="archive-poster" loading="lazy" alt="{{ block.settings.title | escape }}">
            {%- endif -%}
          </a>
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  </div>

  <div class="archives-coming-soon"><span class="type-h2">{{ section.settings.empty_message | default: 'more events coming soon!' }}</span></div>

  <div class="load-more-container">
    <button id="btn-load-more" class="cta-btn">
      <div class="ui-roll roll-hover">
        <span class="type-subRegular1 ui-roll-layer ui-roll-visible">{{ section.settings.load_more_label | default: 'Load More' }}</span>
        <span class="type-subRegular1 ui-roll-layer ui-roll-hidden">{{ section.settings.load_more_label | default: 'Load More' }}</span>
      </div>
    </button>
  </div>
</section>

<script src="{{ 'section-archives.js' | asset_url }}" defer></script>

