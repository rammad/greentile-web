{%- comment -%}
  Outputs data-colors and data-edge attributes for gradient sections.
  Usage: {% render 'gradient-attrs', color1: section.settings.gradient_color_1, color2: section.settings.gradient_color_2, color3: section.settings.gradient_color_3, edge: section.settings.gradient_edge %}
{%- endcomment -%}
data-colors="{{ color1 }}, {{ color2 }}, {{ color3 }}" data-edge="{{ edge }}"