  {
    "name": "Event settings",
    "settings": [
      {
        "type": "paragraph",
        "content": "Event data is read from the Event Ticketing app's metafield: event_ticketing.event_v2 (JSON). This metafield must have Storefront access enabled in Settings → Custom data → Products."
      },
      {
        "type": "text",
        "id": "event_metafield_namespace",
        "label": "Event metafield namespace",
        "default": "event_ticketing",
        "info": "Namespace of the Event Ticketing app's product metafield"
      },
      {
        "type": "text",
        "id": "event_metafield_key",
        "label": "Event metafield key",
        "default": "event_v2",
        "info": "Key of the JSON metafield containing date, time, venue, etc."
      }
    ]
  },
